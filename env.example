# AWS Emulator (MiniStack) Configuration
# Override version via make targets:
#   make start                              → nahuelnucera/ministack:latest (default)
#   make start MINISTACK_VERSION=1.0.0     → any specific version
MINISTACK_VERSION=latest
MINISTACK_VOLUME_DIR=./volume

# AWS Emulator port overrides — use these when running alongside another project
# that also uses MiniStack to avoid host port conflicts:
#   EMULATOR_PORT=4567          → changes the host-side AWS emulator port
#   RDS_BASE_PORT=15500         → shifts RDS instance ports (default: 15432+)
#   ELASTICACHE_BASE_PORT=16400 → shifts ElastiCache ports (default: 16379+)
# EMULATOR_PORT=4566
# RDS_BASE_PORT=15432
# ELASTICACHE_BASE_PORT=16379

# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Application Configuration
NODE_ENV=production
PORT=3031
# Host port Traefik listens on (override with: make start APP_PORT=4040 or set here)
APP_PORT=3030

# API Configuration
API_BASE_URL=https://app-local.localcloudkit.com:3030/api
API_INTERNAL_URL=http://api:3031

# Min ms between throttled /dashboard background refreshes (default 12000). Lower = fresher resources, more list load.
# RESOURCE_CACHE_MIN_STALE_MS=12000

# GUI Configuration
# Frontend uses relative /api paths (no env var needed)
# NEXT_PUBLIC_API_URL=/api

# CORS Configuration
CORS_ORIGIN=https://app-local.localcloudkit.com:3030
SOCKET_IO_ORIGIN=https://app-local.localcloudkit.com:3030

# Mailpit Configuration
MAILPIT_INTERNAL_URL=http://mailpit:8025
MAILPIT_SMTP_PORT=1025

# PostHog Configuration (optional profile)
POSTHOG_INTERNAL_URL=http://posthog-web:8000

# Docker Configuration
COMPOSE_PROJECT_NAME=localcloud-kit
