# LocalStack Configuration
# Override version via make targets:
#   make start                             → localstack/localstack:latest (default)
#   make start-legacy                      → localstack/localstack:4.12
#   make start LOCALSTACK_VERSION=<ver>    → any version
LOCALSTACK_VERSION=latest
LOCALSTACK_VOLUME_DIR=./volume
DEBUG=1

# LocalStack Auth Token (required when using latest with pro features)
# Get your free token at: https://app.localstack.cloud/sign-up
# LOCALSTACK_AUTH_TOKEN=your_token_here

# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Application Configuration
NODE_ENV=production
PORT=3031
# Host port Traefik listens on (override with: make start APP_PORT=4040 or set here)
APP_PORT=3030

# API Configuration
API_BASE_URL=https://app-local.localcloudkit.com:3030/api
API_INTERNAL_URL=http://api:3031

# GUI Configuration
# Frontend uses relative /api paths (no env var needed)
# NEXT_PUBLIC_API_URL=/api

# CORS Configuration
CORS_ORIGIN=https://app-local.localcloudkit.com:3030
SOCKET_IO_ORIGIN=https://app-local.localcloudkit.com:3030

# Mailpit Configuration
MAILPIT_INTERNAL_URL=http://mailpit:8025
MAILPIT_SMTP_PORT=1025

# PostHog Configuration (optional profile)
POSTHOG_INTERNAL_URL=http://posthog-web:8000

# Docker Configuration
COMPOSE_PROJECT_NAME=localstack-template 